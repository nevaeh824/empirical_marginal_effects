. capture program drop export_debt_ctrl_variants

. program define export_debt_ctrl_variants
  1.     use "${out}/theta_full_empirical_panel.dta", clear
  2.     xtset id year, yearly
  3. 
.     gen double B_change = F1.debt_ratio - debt_ratio
  4.     gen double G_level = G_main
  5.     gen double G_theta_full = G_level * theta_hat_full if !missing(G_level, theta_hat_full)
  6. 
.     tempfile appendix_debt
  7.     postfile appdebt str32 model str16 control_set byte z_controls debt_control x_control theta_main ///
>         double b_G se_G t_G p_G ///
>         b_Gtheta se_Gtheta t_Gtheta p_Gtheta ///
>         b_theta se_theta t_theta p_theta ///
>         b_B se_B t_B p_B ///
>         b_X se_X t_X p_X ///
>         N_model N_countries r2 using `appendix_debt', replace
  8. 
.     local model_name1 "Baseline"
  9.     local model_rhs1 "G_level"
 10.     local model_miss1 "B_change, G_level"
 11.     local model_theta1 0
 12. 
.     local model_name2 "Continuous Full-theta"
 13.     local model_rhs2 "G_level G_theta_full"
 14.     local model_miss2 "B_change, G_level, G_theta_full"
 15.     local model_theta2 0
 16. 
.     local model_name3 "Full-theta dynamics"
 17.     local model_rhs3 "G_level G_theta_full theta_hat_full"
 18.     local model_miss3 "B_change, G_level, G_theta_full, theta_hat_full"
 19.     local model_theta3 1
 20. 
.     local ctrl_name1 "Z+B+X"
 21.     local ctrl_rhs1 "debt_ratio X_main ${ctrls}"
 22.     local ctrl_miss1 "debt_ratio, X_main, ${ctrls_miss}"
 23.     local ctrl_z1 1
 24.     local ctrl_b1 1
 25.     local ctrl_x1 1
 26. 
.     local ctrl_name2 "B+X"
 27.     local ctrl_rhs2 "debt_ratio X_main"
 28.     local ctrl_miss2 "debt_ratio, X_main"
 29.     local ctrl_z2 0
 30.     local ctrl_b2 1
 31.     local ctrl_x2 1
 32. 
.     local ctrl_name3 "None"
 33.     local ctrl_rhs3 ""
 34.     local ctrl_miss3 ""
 35.     local ctrl_z3 0
 36.     local ctrl_b3 0
 37.     local ctrl_x3 0
 38. 
.     forvalues m = 1/3 {
 39.         forvalues c = 1/3 {
 40.             local rhs "`model_rhs`m'' `ctrl_rhs`c''"
 41.             local miss "`model_miss`m''"
 42.             if "`ctrl_miss`c''" != "" {
 43.                 local miss "`miss', `ctrl_miss`c''"
 44.             }
 45. 
.             quietly regress B_change `rhs' i.id i.year ///
>                 if theta_sample_full == 1 & !missing(`miss'), vce(robust)
 46. 
.             foreach nm in G Gtheta theta B X {
 47.                 local b_`nm' = .
 48.                 local se_`nm' = .
 49.                 local t_`nm' = .
 50.                 local p_`nm' = .
 51.             }
 52. 
.             local b_G = _b[G_level]
 53.             local se_G = _se[G_level]
 54.             if !missing(`se_G') & `se_G' > 0 {
 55.                 local t_G = `b_G' / `se_G'
 56.                 local p_G = 2 * ttail(e(df_r), abs(`t_G'))
 57.             }
 58. 
.             capture scalar __b_Gtheta = _b[G_theta_full]
 59.             if !_rc {
 60.                 local b_Gtheta = _b[G_theta_full]
 61.                 local se_Gtheta = _se[G_theta_full]
 62.                 if !missing(`se_Gtheta') & `se_Gtheta' > 0 {
 63.                     local t_Gtheta = `b_Gtheta' / `se_Gtheta'
 64.                     local p_Gtheta = 2 * ttail(e(df_r), abs(`t_Gtheta'))
 65.                 }
 66.             }
 67. 
.             capture scalar __b_theta = _b[theta_hat_full]
 68.             if !_rc {
 69.                 local b_theta = _b[theta_hat_full]
 70.                 local se_theta = _se[theta_hat_full]
 71.                 if !missing(`se_theta') & `se_theta' > 0 {
 72.                     local t_theta = `b_theta' / `se_theta'
 73.                     local p_theta = 2 * ttail(e(df_r), abs(`t_theta'))
 74.                 }
 75.             }
 76. 
.             capture scalar __b_B = _b[debt_ratio]
 77.             if !_rc {
 78.                 local b_B = _b[debt_ratio]
 79.                 local se_B = _se[debt_ratio]
 80.                 if !missing(`se_B') & `se_B' > 0 {
 81.                     local t_B = `b_B' / `se_B'
 82.                     local p_B = 2 * ttail(e(df_r), abs(`t_B'))
 83.                 }
 84.             }
 85. 
.             capture scalar __b_X = _b[X_main]
 86.             if !_rc {
 87.                 local b_X = _b[X_main]
 88.                 local se_X = _se[X_main]
 89.                 if !missing(`se_X') & `se_X' > 0 {
 90.                     local t_X = `b_X' / `se_X'
 91.                     local p_X = 2 * ttail(e(df_r), abs(`t_X'))
 92.                 }
 93.             }
 94. 
.             regstats
 95.             local N_model = r(N)
 96.             local N_countries = r(N_countries)
 97.             local r2 = r(r2)
 98. 
.             post appdebt ("`model_name`m''") ("`ctrl_name`c''") ///
>                 (`ctrl_z`c'') (`ctrl_b`c'') (`ctrl_x`c'') (`model_theta`m'') ///
>                 (`b_G') (`se_G') (`t_G') (`p_G') ///
>                 (`b_Gtheta') (`se_Gtheta') (`t_Gtheta') (`p_Gtheta') ///
>                 (`b_theta') (`se_theta') (`t_theta') (`p_theta') ///
>                 (`b_B') (`se_B') (`t_B') (`p_B') ///
>                 (`b_X') (`se_X') (`t_X') (`p_X') ///
>                 (`N_model') (`N_countries') (`r2')
 99.         }
100.     }
101.     postclose appdebt
102. 
.     use `appendix_debt', clear
103.     format b_G se_G t_G p_G b_Gtheta se_Gtheta t_Gtheta p_Gtheta b_theta se_theta t_theta p_theta b_B se_B t_B p_B b_X se_X t_X p_X r2 %12.6f
104.     save "${out}/appendix_debt_change_control_variants.dta", replace
105.     export delimited using "${out}/appendix_debt_change_control_variants.csv", replace
106. end

