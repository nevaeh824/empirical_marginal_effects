. *---------------------------*
. * 2. Helper programs
. *---------------------------*
. capture program drop prep_panel

. program define prep_panel
  1.     capture drop id is_us debt_ratio G_B G_X G_E G_main X_main ${gctrls}
  2. 
.     compress
  3.     encode iso3, gen(id)
  4.     xtset id year, yearly
  5.     isid iso3 year, sort
  6. 
.     gen byte is_us = inlist(strupper(strtrim(iso3)), "USA", "US") | regexm(strupper(country_name), "UNITED STATES")
  7.     label var is_us "United States indicator"
  8. 
.     capture confirm variable ${g_source}
  9.     if _rc {
 10.         display as error "G source variable not found: ${g_source}"
 11.         exit 111
 12.     }
 13.     capture confirm variable ${x_source}
 14.     if _rc {
 15.         display as error "X source variable not found: ${x_source}"
 16.         exit 111
 17.     }
 18. 
.     replace bond_spreads = bond_spreads * 0.01 if !missing(bond_spreads)
 19. 
.     gen double G_main = ${g_source} if !missing(${g_source})
 20.     gen double X_main = ${x_source} if !missing(${x_source})
 21.     replace G_main = G_main * 0.01 if !missing(G_main)
 22.     replace X_main = X_main * 0.01 if !missing(X_main)
 23.     replace exposure100 = exposure100 * 0.01 if !missing(exposure100)
 24.     foreach z in lnrgdp growth inflation_cpi OB_gdp reserves gee rqe tt {
 25.         replace `z' = `z' * 0.01 if !missing(`z')
 26.     }
 27. 
.     gen double debt_ratio = debt_gdp * 0.01 if !missing(debt_gdp)
 28.     label var debt_ratio "Debt/GDP ratio, scaled by 0.01"
 29. 
.     gen double G_B = G_main * debt_ratio if !missing(G_main, debt_ratio)
 30.     gen double G_X = G_main * X_main if !missing(G_main, X_main)
 31.     gen double G_E = G_main * exposure100 if !missing(G_main, exposure100)
 32.     label var G_B "G x B"
 33.     label var G_X "G x X"
 34.     label var G_E "G x E"
 35.     foreach z in lnrgdp growth inflation_cpi OB_gdp reserves gee rqe tt {
 36.         gen double G_`z' = G_main * `z' if !missing(G_main, `z')
 37.         label var G_`z' "G x `z'"
 38.     }
 39. 
.     label var bond_spreads "10-year sovereign spread, s^g, scaled by 0.01"
 40.     label var bond_10y "10-year sovereign yield"
 41.     label var G_main "G source ${g_source}, scaled by 0.01"
 42.     label var X_main "X source ${x_source}, scaled by 0.01"
 43.     label var exposure100 "E (ND-GAIN exposure proxy), scaled by 0.01"
 44.     label var lnrgdp "Real GDP, scaled by 0.01"
 45.     label var growth "Real GDP growth, scaled by 0.01"
 46.     label var inflation_cpi "CPI inflation, scaled by 0.01"
 47.     label var OB_gdp "Overall balance/GDP, scaled by 0.01"
 48.     label var reserves "International reserves, scaled by 0.01"
 49.     label var gee "Government effectiveness, scaled by 0.01"
 50.     label var rqe "Regulatory quality, scaled by 0.01"
 51.     label var tt "Terms of trade, scaled by 0.01"
 52. end

. 
. capture program drop texcell

. program define texcell, rclass
  1.     args var
  2.     tempname b se tstat p
  3. 
.     capture scalar `b' = _b[`var']
  4.     if _rc {
  5.         return local coef ""
  6.         return local se ""
  7.         exit
  8.     }
  9.     capture scalar `se' = _se[`var']
 10.     if _rc | missing(`b') | missing(`se') | `se' <= 0 {
 11.         return local coef ""
 12.         return local se ""
 13.         exit
 14.     }
 15. 
.     scalar `tstat' = `b' / `se'
 16. 
.     if !missing(e(df_r)) {
 17.         scalar `p' = 2 * ttail(e(df_r), abs(`tstat'))
 18.     }
 19.     else {
 20.         scalar `p' = 2 * normal(-abs(`tstat'))
 21.     }
 22. 
.     local stars ""
 23.     if scalar(`p') < 0.01 local stars "***"
 24.     else if scalar(`p') < 0.05 local stars "**"
 25.     else if scalar(`p') < 0.10 local stars "*"
 26. 
.     local coef : display %9.3f scalar(`b')
 27.     local coef = strtrim("`coef'")
 28.     local tstatf : display %9.3f scalar(`tstat')
 29.     local tstatf = strtrim("`tstatf'")
 30. 
.     return local coef "`coef'`stars'"
 31.     return local se "(`tstatf')"
 32. end

. 
. capture program drop regstats

. program define regstats, rclass
  1.     tempvar touse tag
  2.     gen byte `touse' = e(sample)
  3.     egen byte `tag' = tag(id) if `touse'
  4.     quietly count if `tag'
  5.     return scalar N_countries = r(N)
  6.     return scalar N = e(N)
  7.     capture return scalar r2 = e(r2_a)
  8.     if _rc return scalar r2 = .
  9. end

. 
. capture program drop collect_model

. program define collect_model, rclass
  1.     syntax, Prefix(name)
  2. 
.     foreach v in G_main debt_ratio X_main exposure100 G_B G_X G_E {
  3.         texcell `v'
  4.         return local `v'_b "`r(coef)'"
  5.         return local `v'_se "`r(se)'"
  6.     }
  7. 
.     regstats
  8.     return scalar N = r(N)
  9.     return scalar N_countries = r(N_countries)
 10.     return scalar r2 = r(r2)
 11. end

. 
. capture program drop run_deltaB_kink

. program define run_deltaB_kink
  1.     syntax, Trim(real) Horizon(integer) Specname(string) [Suffix(string) THETACONTROLS CLUSTER LAGTHETA CONTROLSET(string)]
  2. 
.     local controlset = lower(strtrim("`controlset'"))
  3.     if "`controlset'" == "" {
  4.         local controlset "z"
  5.     }
  6.     local control_rhs ""
  7.     local control_miss ""
  8.     if "`controlset'" == "z" {
  9.         local control_rhs "${ctrls}"
 10.         local control_miss "${ctrls_miss}"
 11.     }
 12.     else if "`controlset'" == "zbx" {
 13.         local control_rhs "debt_ratio X_main ${ctrls}"
 14.         local control_miss "debt_ratio, X_main, ${ctrls_miss}"
 15.     }
 16.     else if "`controlset'" == "bx" {
 17.         local control_rhs "debt_ratio X_main"
 18.         local control_miss "debt_ratio, X_main"
 19.     }
 20.     else if "`controlset'" == "none" {
 21.         local control_rhs ""
 22.         local control_miss ""
 23.     }
 24.     else {
 25.         display as error "Unknown controlset: `controlset'. Use z, zbx, bx, or none."
 26.         exit 198
 27.     }
 28. 
.     use "${out}/theta_full_empirical_panel.dta", clear
 29.     xtset id year, yearly
 30. 
.     gen double B_change = F`horizon'.debt_ratio - debt_ratio
 31.     gen double G_level = G_main
 32.     if "`lagtheta'" != "" {
 33.         gen double theta_kink = L1.theta_hat_full
 34.         label var theta_kink "Lagged Full-theta"
 35.     }
 36.     else {
 37.         gen double theta_kink = theta_hat_full
 38.         label var theta_kink "Full-theta"
 39.     }
 40.     format theta_kink %20.15g
 41. 
.     local sample_miss "B_change, G_level, theta_kink"
 42.     if "`control_miss'" != "" {
 43.         local sample_miss "`sample_miss', `control_miss'"
 44.     }
 45.     gen byte sample_kink = theta_sample_full == 1 ///
>         & !missing(`sample_miss')
 46.     label var sample_kink "Single-crossing kink estimation sample"
 47. 
.     local vceopt "vce(robust)"
 48.     if "`cluster'" != "" {
 49.         local vceopt "vce(cluster id)"
 50.     }
 51. 
.     local grid_dta "${out}/table7_deltaB_kink_cutoff_grid`suffix'.dta"
 52.     local grid_csv "${out}/table7_deltaB_kink_cutoff_grid`suffix'.csv"
 53.     local selected_dta "${out}/table7_deltaB_kink_selected_cutoff`suffix'.dta"
 54.     local selected_csv "${out}/table7_deltaB_kink_selected_cutoff`suffix'.csv"
 55.     local marginal_dta "${out}/table7_deltaB_kink_marginal_effects`suffix'.dta"
 56.     local marginal_csv "${out}/table7_deltaB_kink_marginal_effects`suffix'.csv"
 57. 
.     tempfile kink_grid
 58.     postfile kinkgrid double cutoff rss N_grid N_low N_high share_low share_high ///
>         b_low se_low t_low p_low b_high se_high t_high p_high byte sign_ok using `kink_grid', replace
 59. 
.     quietly count if sample_kink == 1
 60.     local N_total = r(N)
 61.     if `N_total' == 0 {
 62.         display as error "No observations in kink sample for suffix `suffix'."
 63.         exit 499
 64.     }
 65. 
.     quietly levelsof theta_kink if sample_kink == 1, local(cutoffs_kink)
 66.     foreach c of local cutoffs_kink {
 67.         capture drop kink_L_tmp kink_H_tmp kink_G_low_tmp kink_G_high_tmp
 68. 
.         quietly count if sample_kink == 1 & theta_kink < `c'
 69.         local N_low = r(N)
 70.         quietly count if sample_kink == 1 & theta_kink >= `c'
 71.         local N_high = r(N)
 72.         local share_low = `N_low' / `N_total'
 73.         local share_high = `N_high' / `N_total'
 74. 
.         if `share_low' >= (`trim' / 100) & `share_high' >= (`trim' / 100) {
 75.             gen double kink_L_tmp = max(`c' - theta_kink, 0) if sample_kink == 1
 76.             gen double kink_H_tmp = max(theta_kink - `c', 0) if sample_kink == 1
 77.             gen double kink_G_low_tmp = G_level * kink_L_tmp if sample_kink == 1
 78.             gen double kink_G_high_tmp = G_level * kink_H_tmp if sample_kink == 1
 79. 
.             local rhs "kink_G_low_tmp kink_G_high_tmp"
 80.             if "`thetacontrols'" != "" {
 81.                 local rhs "`rhs' theta_kink kink_H_tmp"
 82.             }
 83.             local rhs "`rhs' `control_rhs'"
 84. 
.             capture quietly regress B_change `rhs' i.id i.year ///
>                 if sample_kink == 1, `vceopt'
 85.             if !_rc {
 86.                 local rss = e(rss)
 87.                 local N_grid = e(N)
 88.                 local b_low = _b[kink_G_low_tmp]
 89.                 local se_low = _se[kink_G_low_tmp]
 90.                 local b_high = _b[kink_G_high_tmp]
 91.                 local se_high = _se[kink_G_high_tmp]
 92.                 local t_low = .
 93.                 local p_low = .
 94.                 if !missing(`se_low') & `se_low' > 0 {
 95.                     local t_low = `b_low' / `se_low'
 96.                     if !missing(e(df_r)) {
 97.                         local p_low = 2 * ttail(e(df_r), abs(`t_low'))
 98.                     }
 99.                     else {
100.                         local p_low = 2 * normal(-abs(`t_low'))
101.                     }
102.                 }
103.                 local t_high = .
104.                 local p_high = .
105.                 if !missing(`se_high') & `se_high' > 0 {
106.                     local t_high = `b_high' / `se_high'
107.                     if !missing(e(df_r)) {
108.                         local p_high = 2 * ttail(e(df_r), abs(`t_high'))
109.                     }
110.                     else {
111.                         local p_high = 2 * normal(-abs(`t_high'))
112.                     }
113.                 }
114.                 local sign_ok = (`b_low' > 0 & `b_high' < 0)
115. 
.                 post kinkgrid (`c') (`rss') (`N_grid') (`N_low') (`N_high') ///
>                     (`share_low') (`share_high') ///
>                     (`b_low') (`se_low') (`t_low') (`p_low') ///
>                     (`b_high') (`se_high') (`t_high') (`p_high') (`sign_ok')
116.             }
117.         }
118.     }
119.     postclose kinkgrid
120. 
.     use `kink_grid', clear
121.     quietly count
122.     if r(N) == 0 {
123.         display as error "No admissible kink cutoff was found for suffix `suffix'."
124.         exit 498
125.     }
126.     sort cutoff
127.     format cutoff %20.15g
128.     format rss share_low share_high b_low se_low t_low p_low b_high se_high t_high p_high %12.6f
129.     save "`grid_dta'", replace
130.     export delimited using "`grid_csv'", replace
131. 
.     sort rss cutoff
132.     local c_rss = cutoff[1]
133.     preserve
134.         keep if sign_ok == 1
135.         quietly count
136.         local has_sc = r(N) > 0
137.         if `has_sc' {
138.             sort rss cutoff
139.             local c_sc = cutoff[1]
140.         }
141.     restore
142. 
.     use "${out}/theta_full_empirical_panel.dta", clear
143.     xtset id year, yearly
144.     gen double B_change = F`horizon'.debt_ratio - debt_ratio
145.     gen double G_level = G_main
146.     if "`lagtheta'" != "" {
147.         gen double theta_kink = L1.theta_hat_full
148.     }
149.     else {
150.         gen double theta_kink = theta_hat_full
151.     }
152.     format theta_kink %20.15g
153.     local sample_miss "B_change, G_level, theta_kink"
154.     if "`control_miss'" != "" {
155.         local sample_miss "`sample_miss', `control_miss'"
156.     }
157.     gen byte sample_kink = theta_sample_full == 1 ///
>         & !missing(`sample_miss')
158. 
.     tempfile kink_selected
159.     postfile kinksel str32 selection_rule double cutoff rss sign_ok N_model N_countries ///
>         share_low share_high b_low se_low t_low p_low p_low_positive ///
>         b_high se_high t_high p_high p_high_negative r2 using `kink_selected', replace
160. 
.     foreach rule in rss_min_cutoff sign_consistent_cutoff {
161.         local has_rule = 1
162.         if "`rule'" == "rss_min_cutoff" {
163.             local c_sel = `c_rss'
164.         }
165.         if "`rule'" == "sign_consistent_cutoff" {
166.             if `has_sc' {
167.                 local c_sel = `c_sc'
168.             }
169.             else {
170.                 local has_rule = 0
171.             }
172.         }
173. 
.         if `has_rule' {
174.             capture drop kink_L kink_H kink_G_low kink_G_high
175.             gen double kink_L = max(`c_sel' - theta_kink, 0) if sample_kink == 1
176.             gen double kink_H = max(theta_kink - `c_sel', 0) if sample_kink == 1
177.             gen double kink_G_low = G_level * kink_L if sample_kink == 1
178.             gen double kink_G_high = G_level * kink_H if sample_kink == 1
179. 
.             local rhs "kink_G_low kink_G_high"
180.             if "`thetacontrols'" != "" {
181.                 local rhs "`rhs' theta_kink kink_H"
182.             }
183.             local rhs "`rhs' `control_rhs'"
184. 
.             quietly regress B_change `rhs' i.id i.year ///
>                 if sample_kink == 1, `vceopt'
185. 
.             local rss_sel = e(rss)
186.             local b_low = _b[kink_G_low]
187.             local se_low = _se[kink_G_low]
188.             local b_high = _b[kink_G_high]
189.             local se_high = _se[kink_G_high]
190.             local t_low = .
191.             local p_low = .
192.             local p_low_positive = .
193.             if !missing(`se_low') & `se_low' > 0 {
194.                 local t_low = `b_low' / `se_low'
195.                 if !missing(e(df_r)) {
196.                     local p_low = 2 * ttail(e(df_r), abs(`t_low'))
197.                     local p_low_positive = ttail(e(df_r), `t_low')
198.                 }
199.                 else {
200.                     local p_low = 2 * normal(-abs(`t_low'))
201.                     local p_low_positive = normal(-`t_low')
202.                 }
203.             }
204.             local t_high = .
205.             local p_high = .
206.             local p_high_negative = .
207.             if !missing(`se_high') & `se_high' > 0 {
208.                 local t_high = `b_high' / `se_high'
209.                 if !missing(e(df_r)) {
210.                     local p_high = 2 * ttail(e(df_r), abs(`t_high'))
211.                     local p_high_negative = ttail(e(df_r), -`t_high')
212.                 }
213.                 else {
214.                     local p_high = 2 * normal(-abs(`t_high'))
215.                     local p_high_negative = normal(`t_high')
216.                 }
217.             }
218.             local sign_ok = (`b_low' > 0 & `b_high' < 0)
219. 
.             tempvar esample tag_country
220.             gen byte `esample' = e(sample)
221.             quietly count if `esample' == 1 & theta_kink < `c_sel'
222.             local N_low_sel = r(N)
223.             quietly count if `esample' == 1 & theta_kink >= `c_sel'
224.             local N_high_sel = r(N)
225.             local share_low_sel = `N_low_sel' / e(N)
226.             local share_high_sel = `N_high_sel' / e(N)
227.             egen byte `tag_country' = tag(id) if `esample'
228.             quietly count if `tag_country'
229.             local N_countries = r(N)
230.             local N_model = e(N)
231.             local r2 = e(r2_a)
232. 
.             post kinksel ("`rule'") (`c_sel') (`rss_sel') (`sign_ok') ///
>                 (`N_model') (`N_countries') (`share_low_sel') (`share_high_sel') ///
>                 (`b_low') (`se_low') (`t_low') (`p_low') (`p_low_positive') ///
>                 (`b_high') (`se_high') (`t_high') (`p_high') (`p_high_negative') (`r2')
233.         }
234.         else {
235.             post kinksel ("`rule'") (.) (.) (.) (.) (.) (.) (.) (.) (.) (.) (.) (.) (.) (.) (.) (.) (.) (.)
236.         }
237.     }
238.     postclose kinksel
239. 
.     preserve
240.         use `kink_selected', clear
241.         format cutoff %20.15g
242.         format rss share_low share_high b_low se_low t_low p_low p_low_positive b_high se_high t_high p_high p_high_negative r2 %12.6f
243.         save "`selected_dta'", replace
244.         export delimited using "`selected_csv'", replace
245.     restore
246. 
.     capture drop kink_L kink_H kink_G_low kink_G_high
247.     gen double kink_L = max(`c_rss' - theta_kink, 0) if sample_kink == 1
248.     gen double kink_H = max(theta_kink - `c_rss', 0) if sample_kink == 1
249.     gen double kink_G_low = G_level * kink_L if sample_kink == 1
250.     gen double kink_G_high = G_level * kink_H if sample_kink == 1
251. 
.     local rhs "kink_G_low kink_G_high"
252.     if "`thetacontrols'" != "" {
253.         local rhs "`rhs' theta_kink kink_H"
254.     }
255.     local rhs "`rhs' `control_rhs'"
256. 
.     quietly regress B_change `rhs' i.id i.year ///
>         if sample_kink == 1, `vceopt'
257.     quietly summarize theta_kink if e(sample), detail
258.     local theta_q10 = r(p10)
259.     local theta_q25 = r(p25)
260.     local theta_q50 = r(p50)
261.     local theta_q75 = r(p75)
262.     local theta_q90 = r(p90)
263. 
.     tempfile kink_marginal
264.     postfile kinkme str8 theta_quantile double theta_point marginal_effect ///
>         standard_error t_stat p_value using `kink_marginal', replace
265. 
.     foreach q in 10 25 50 75 90 {
266.         if `q' == 10 local theta_point = `theta_q10'
267.         if `q' == 25 local theta_point = `theta_q25'
268.         if `q' == 50 local theta_point = `theta_q50'
269.         if `q' == 75 local theta_point = `theta_q75'
270.         if `q' == 90 local theta_point = `theta_q90'
271. 
.         local me = 0
272.         local se_me = 0
273.         local t_me = .
274.         local p_me = .
275.         if `theta_point' < `c_rss' {
276.             local mult = `c_rss' - `theta_point'
277.             quietly lincom (`mult') * kink_G_low
278.             local me = r(estimate)
279.             local se_me = r(se)
280.             local t_me = r(t)
281.             local p_me = r(p)
282.         }
283.         else if `theta_point' > `c_rss' {
284.             local mult = `theta_point' - `c_rss'
285.             quietly lincom (`mult') * kink_G_high
286.             local me = r(estimate)
287.             local se_me = r(se)
288.             local t_me = r(t)
289.             local p_me = r(p)
290.         }
291. 
.         post kinkme ("p`q'") (`theta_point') (`me') (`se_me') (`t_me') (`p_me')
292.     }
293.     postclose kinkme
294. 
.     preserve
295.         use `kink_marginal', clear
296.         format theta_point marginal_effect standard_error t_stat p_value %12.6f
297.         save "`marginal_dta'", replace
298.         export delimited using "`marginal_csv'", replace
299.     restore
300. 
.     display as result "Kink model complete: suffix=`suffix', spec=`specname', controlset=`controlset', trim=`trim', horizon=`horizon'."
301. end

