. * 7.3 Marginal-relief grouped debt-change heterogeneity regressions
. *---------------------------*
. use "${out}/theta_full_empirical_panel.dta", clear

. xtset id year, yearly

Panel variable: id (strongly balanced)
 Time variable: year, 1995 to 2023
         Delta: 1 year

. 
. gen double B_change = F1.debt_ratio - debt_ratio
(148 missing values generated)

. gen double G_level = G_main

. label var B_change "Next-period change in debt/GDP"

. label var G_level "Selected G"

. 
. gen byte sample_t7mg = theta_sample_full == 1 ///
>     & !missing(B_change, G_level, mG_hat_full, ${ctrls_miss})

. label var sample_t7mg "Marginal-relief grouped heterogeneity sample"

. 
. quietly _pctile mG_hat_full if sample_t7mg == 1, p(20 40 60 80)

. local mg_p20 = r(r1)

. local mg_p40 = r(r2)

. local mg_p60 = r(r3)

. local mg_p80 = r(r4)

. 
. gen byte mG_group20 = .
(1,798 missing values generated)

. replace mG_group20 = 1 if sample_t7mg == 1 & mG_hat_full <= `mg_p20'
(212 real changes made)

. replace mG_group20 = 2 if sample_t7mg == 1 & mG_hat_full > `mg_p20' & mG_hat_full <= `mg_p40'
(212 real changes made)

. replace mG_group20 = 3 if sample_t7mg == 1 & mG_hat_full > `mg_p40' & mG_hat_full <= `mg_p60'
(212 real changes made)

. replace mG_group20 = 4 if sample_t7mg == 1 & mG_hat_full > `mg_p60' & mG_hat_full <= `mg_p80'
(212 real changes made)

. replace mG_group20 = 5 if sample_t7mg == 1 & mG_hat_full > `mg_p80'
(212 real changes made)

. label define mG_group20_lbl 1 "0-20%" 2 "20-40%" 3 "40-60%" 4 "60-80%" 5 "80-100%", replace

. label values mG_group20 mG_group20_lbl

. 
. tempfile t7_mG_heterogeneity

. postfile t7mg str24 group str12 split double cutoff_low cutoff_high ///
>     b_G se_G t_G p_G N_model N_countries r2 using `t7_mG_heterogeneity', replace
(file C:\Users\chenyu\AppData\Local\Temp\ST_428_00000h.tmp not found)

. 
. local t7mg_name1 "0-20%"

. local t7mg_split1 "mG20"

. local t7mg_cond1 "mG_group20 == 1"

. local t7mg_low1 "."

. local t7mg_high1 "`mg_p20'"

. 
. local t7mg_name2 "20-40%"

. local t7mg_split2 "mG20"

. local t7mg_cond2 "mG_group20 == 2"

. local t7mg_low2 "`mg_p20'"

. local t7mg_high2 "`mg_p40'"

. 
. local t7mg_name3 "40-60%"

. local t7mg_split3 "mG20"

. local t7mg_cond3 "mG_group20 == 3"

. local t7mg_low3 "`mg_p40'"

. local t7mg_high3 "`mg_p60'"

. 
. local t7mg_name4 "60-80%"

. local t7mg_split4 "mG20"

. local t7mg_cond4 "mG_group20 == 4"

. local t7mg_low4 "`mg_p60'"

. local t7mg_high4 "`mg_p80'"

. 
. local t7mg_name5 "80-100%"

. local t7mg_split5 "mG20"

. local t7mg_cond5 "mG_group20 == 5"

. local t7mg_low5 "`mg_p80'"

. local t7mg_high5 "."

. 
. forvalues j = 1/5 {
  2.     quietly regress B_change G_level ${ctrls} i.id i.year ///
>         if `t7mg_cond`j'', vce(robust)
  3. 
.     texcell G_level
  4.     local t7mg_G_b`j' "`r(coef)'"
  5.     local t7mg_G_se`j' "`r(se)'"
  6. 
.     foreach z of global ctrls {
  7.         texcell `z'
  8.         local t7mg_`z'_b`j' "`r(coef)'"
  9.         local t7mg_`z'_se`j' "`r(se)'"
 10.     }
 11. 
.     local b_G = _b[G_level]
 12.     local se_G = _se[G_level]
 13.     local t_G = `b_G' / `se_G'
 14.     local p_G = 2 * ttail(e(df_r), abs(`t_G'))
 15. 
.     regstats
 16.     local t7mg_N`j' = r(N)
 17.     local t7mg_Nc`j' = r(N_countries)
 18.     local t7mg_r2`j' = r(r2)
 19. 
.     post t7mg ("`t7mg_name`j''") ("`t7mg_split`j''") (`t7mg_low`j'') (`t7mg_high`j'') ///
>         (`b_G') (`se_G') (`t_G') (`p_G') ///
>         (`t7mg_N`j'') (`t7mg_Nc`j'') (`t7mg_r2`j'')
 20. }

. postclose t7mg

. 
