. capture program drop export_fig3_kink_curve

. program define export_fig3_kink_curve
  1.     use "${out}/theta_full_empirical_panel.dta", clear
  2.     xtset id year, yearly
  3. 
.     preserve
  4.         use "${out}/table7_deltaB_kink_selected_cutoff_notheta.dta", clear
  5.         keep if selection_rule == "rss_min_cutoff"
  6.         local c_sel : display %21.16g cutoff[1]
  7.         local c_sel = strtrim("`c_sel'")
  8.     restore
  9. 
.     gen double B_change = F1.debt_ratio - debt_ratio
 10.     gen double G_level = G_main
 11.     gen double theta_kink = theta_hat_full
 12.     format theta_kink %20.15g
 13.     gen byte sample_kink = theta_sample_full == 1 ///
>         & !is_us ///
>         & !missing(B_change, G_level, theta_kink, ${ctrls_miss})
 14. 
.     gen double kink_L = max(`c_sel' - theta_kink, 0) if sample_kink == 1
 15.     gen double kink_H = max(theta_kink - `c_sel', 0) if sample_kink == 1
 16.     gen double kink_G_low = G_level * kink_L if sample_kink == 1
 17.     gen double kink_G_high = G_level * kink_H if sample_kink == 1
 18. 
.     quietly regress B_change kink_G_low kink_G_high ${ctrls} i.id i.year ///
>         if sample_kink == 1, vce(robust)
 19. 
.     matrix V_fig3 = e(V)
 20.     local i_a = colnumb(V_fig3, "kink_G_low")
 21.     local i_b = colnumb(V_fig3, "kink_G_high")
 22.     local a_hat = _b[kink_G_low]
 23.     local b_hat = _b[kink_G_high]
 24. 
.     tempvar esample tag_country
 25.     gen byte `esample' = e(sample)
 26.     egen byte `tag_country' = tag(id) if `esample'
 27.     quietly count if `tag_country'
 28.     local N_countries = r(N)
 29.     local N_model = e(N)
 30. 
.     file open fh using "${out}/figure3_kink_marginal_effect_notheta_coefficients.csv", write replace text
 31.     file write fh "term,coef,var_a,var_b,cutoff,N_model,N_countries" _n
 32.     foreach row in kink_G_low kink_G_high {
 33.         local i_row = colnumb(V_fig3, "`row'")
 34.         local coef : display %20.15g _b[`row']
 35.         local v_a : display %20.15g V_fig3[`i_row', `i_a']
 36.         local v_b : display %20.15g V_fig3[`i_row', `i_b']
 37.         local cutoff_s : display %21.16g `c_sel'
 38.         local cutoff_s = strtrim("`cutoff_s'")
 39.         file write fh "`row',`coef',`v_a',`v_b',`cutoff_s',`N_model',`N_countries'" _n
 40.     }
 41.     file close fh
 42. 
.     quietly _pctile theta_kink if `esample' == 1, p(10 90)
 43.     local theta_p10 = r(r1)
 44.     local theta_p90 = r(r2)
 45.     local theta_step = (`theta_p90' - `theta_p10') / 99
 46. 
.     tempfile fig3_curve
 47.     postfile fig3 int grid_index double theta double cutoff double low_part double high_part ///
>         double marginal_effect double se double ci_low double ci_high double a_coef double b_coef ///
>         double N_model double N_countries using `fig3_curve', replace
 48. 
.     forvalues j = 1/100 {
 49.         local theta_j = `theta_p10' + (`j' - 1) * `theta_step'
 50.         local low_j = max(`c_sel' - `theta_j', 0)
 51.         local high_j = max(`theta_j' - `c_sel', 0)
 52.         quietly lincom (`low_j') * kink_G_low + (`high_j') * kink_G_high
 53.         local me = r(estimate)
 54.         local se = r(se)
 55.         local ci_low = `me' - 1.96 * `se'
 56.         local ci_high = `me' + 1.96 * `se'
 57.         post fig3 (`j') (`theta_j') (`c_sel') (`low_j') (`high_j') ///
>             (`me') (`se') (`ci_low') (`ci_high') (`a_hat') (`b_hat') (`N_model') (`N_countries')
 58.     }
 59.     postclose fig3
 60. 
.     use `fig3_curve', clear
 61.     format theta cutoff low_part high_part marginal_effect se ci_low ci_high a_coef b_coef %21.16g
 62.     save "${out}/figure3_kink_marginal_effect_notheta_continuous.dta", replace
 63.     export delimited using "${out}/figure3_kink_marginal_effect_notheta_continuous.csv", replace datafmt
 64. end

